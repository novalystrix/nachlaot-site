<style media="screen">
.subscribe_to_newsletter{height:196px;width:100%;overflow:visible;box-sizing:border-box;width:1200px;margin-right:auto;margin-left:auto;margin-top:90px;background-image:url(/public/img/hp/subscribe_to_newsletter.png);background-size:60px 61px;background-repeat:no-repeat;background-position:1114px 20px;}
.subscribe_to_newsletter_inner{width:1200px;height:192px;margin-right:-8px;border:1px solid #58d489;border-radius:4px;overflow:hidden;padding:18px 135px;background-color:white!important;}
.subscribe_to_newsletter .inner_stl{margin-right:0;margin-left:0;width:100%;box-sizing:border-box;padding-top:22px;padding-right:2px}
.subscribe_to_newsletter .inner_stl .subform{width:11%;float:right;box-sizing:border-box}
