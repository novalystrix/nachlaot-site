#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item button.jump{width:71px;height:32.5px;line-height:32.5px;border-radius:4px;box-shadow:.9px 1.8px 5px 0 rgba(0,0,0,.07);background-color:#4ab07e;color:#fff;font-size:17px;font-family:KalisherBold;text-align:center}
