#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item .content-content-wrapper .ui .td{float:right;font-size:17px}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item .content-content-wrapper .updated-at{font-size:17px;padding-top:9px;text-decoration:none!important;border-bottom:0!important}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item a,
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item a *{text-decoration:none!important;border-bottom:0!important}
