.subscribe_to_newsletter .subform.first h4{color:#2ba96c;font-size:36px;font-weight:bold;margin-top:2px;margin-bottom:0;letter-spacing:1px}
.subscribe_to_newsletter .subform.first p{margin-top:10px;color:#2e3e4b;font-size:28px;line-height:1.08;letter-spacing:1.1px}
.subscribe_to_newsletter .subform.first p.alert-success{color:#58d489}
.subscribe_to_newsletter .subform.first p.alert-danger{color:red}
.subscribe_to_newsletter .inner_stl input{border:1px solid #58d489;border-radius:4px;font-size:24px;text-align:left;direction:ltr;padding:5px 2.2%}
.subscribe_to_newsletter .inner_stl input::-webkit-input-placeholder{text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input::-moz-placeholder{text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input:-ms-input-placeholder{text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input:-moz-placeholder{text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input.error{border:1px solid red}
.subscribe_to_newsletter .inner_stl input.stn-email{width:33.7%;margin-left:.4%;padding-right:2.2%}
.subscribe_to_newsletter .inner_stl input.stn-name{width:40.9%;margin-left:.4%;padding-right:2.2%;text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input.stn-name.input-email-rtlltr{text-align:left;direction:ltr}
.subscribe_to_newsletter .inner_stl input.stn-name.input-email-rtlltr::-webkit-input-placeholder{text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input.stn-name.input-email-rtlltr::-moz-placeholder{text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input.stn-name.input-email-rtlltr:-ms-input-placeholder{text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input.stn-name.input-email-rtlltr:-moz-placeholder{text-align:right;direction:rtl}
.subscribe_to_newsletter .inner_stl input[type="submit"]#subscribe_to_newsletter{width:21.7%;padding:5px 0;font-size:27px;letter-spacing:1.5px;border:0;color:#fff;border-radius:4px;cursor:pointer;text-align:center;direction:rtl}
.subscribe_to_newsletter ::-webkit-input-placeholder{color:#888}
.subscribe_to_newsletter ::-moz-placeholder{color:#888}
.subscribe_to_newsletter :-ms-input-placeholder{color:#888}
.subscribe_to_newsletter :-moz-placeholder{color:#888}
</style>

