.user-pu-button .spinner.not-active{display:none}
.user-pu-button .spinner{width:20px;height:20px;position:relative;margin:0 auto;float:right;margin-top:2px;margin-right:0;margin-left:-9px;}
.user-pu-button .double-bounce1,.user-pu-button .double-bounce2{width:100%;height:100%;border-radius:50%;background-color:#fff;opacity:.6;position:absolute;top:0;left:0;-webkit-animation:sk-bounce 2s infinite ease-in-out;animation:sk-bounce 2s infinite ease-in-out}
.user-pu-button .double-bounce2{-webkit-animation-delay:-1s;animation-delay:-1s}
@-webkit-keyframes sk-bounce {
0%,100%{-webkit-transform:scale(0.0)}
50%{-webkit-transform:scale(1.0)}
}
@keyframes  sk-bounce {
0%,100%{transform:scale(0.0);-webkit-transform:scale(0.0)}
50%{transform:scale(1.0);-webkit-transform:scale(1.0)}
}
