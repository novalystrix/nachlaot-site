.accessability-wrapper {
  background-image: none;
  height: 545px;
  padding: 12px 6px;

}
.accessability-wrapper .a-tr{
  width: 100%;
  height: 120px!important;
  display: flex;
  clear:both;
}
.accessability-wrapper .a-tr.before-last{
  margin-top:0;
}
.accessability-wrapper .a-tr.last{
  margin-top:16px;
}
.accessability-wrapper .a-tr .a-td{
  flex-basis: 50%;
  border-bottom:2px solid rgba(0, 0, 0, 0.07);
  height: 120px!important;
  clear:both;
}
.accessability-wrapper .a-tr > .a-td:nth-child(1) {
  border-left:1px solid rgba(0, 0, 0, 0.07);
}
.accessability-wrapper .a-tr > .a-td:nth-child(2) {
  border-right:1px solid rgba(0, 0, 0, 0.07);
}
