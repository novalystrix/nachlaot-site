#my_properties_in_header_27Xv_list{width:360.5px;position:absolute;top:70px;right:41%;border-radius:6.5px;padding-top:29px;margin-top:-32px}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item{height:94.5px;overflow:hidden;padding:10.9px 11.6px;border-bottom:1px solid #eaeaea;background-color:#fff}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item_wrapper .my_properties_in_header_27Xv_list_item:nth-child(1){border-top-right-radius:6.5px;border-top-left-radius:6.5px}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item_wrapper .my_properties_in_header_27Xv_list_item:nth-last-child(1){border-bottom-right-radius:6.5px;border-bottom-left-radius:6.5px}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item{position:relative}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item:hover h3{text-decoration:underline}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item .fr{float:right}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item .fl{float:left}
.my_properties.fr{margin-top:28.5px;padding-right:30px;padding-top:15.7px}
.my_properties.fr.hover{cursor:pointer}
.my_properties.fr .img{float:right;width:15.5px;height:13.5px;background-size:cover;background-image:url(/_dec18/images/top_menu/my_properties.png?v=010421a1);position:relative}
.my_properties.fr .img .icon-wrapper{position:absolute;bottom:-4px;left:-3px;background-color:#fff;color:#c00;font-size:9px;width:12px;height:12px;line-height:12px;text-align:center;display:block}
.my_properties.fr .img .icon-wrapper svg{visibility:visible}
.my_properties.fr .txt{float:right;font-size:18px;color:rgba(0,0,0,.4);padding-right:6px;line-height:14.5px}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item .img{width:78px;height:64.1px;background-size:cover;position:relative}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item .img .icon-wrapper{background-color:#fff;padding:1px;color:#324253;position:absolute;top:-3px;right:-5px;display:block;cursor:pointer;font-size:16px;padding-left:4px}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item.idle .img .icon-wrapper{display:none}
#my_properties_in_header_27Xv_list .my_properties_in_header_27Xv_list_item h3{font-size:18px;font-family:KalisherBold;color:#58636e;height:20px;overflow:hidden;margin-bottom:6px;white-space:nowrap}
